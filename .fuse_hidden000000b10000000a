    <script>
        // ───────────────────────────────────────────────────────────
        // THE FORK — interactive state machine.
        // Chosen path reveals its own logic trail + converges on finale.
        // ───────────────────────────────────────────────────────────
        (function () {
            const pathsEl  = document.getElementById('forkPaths');
            const revealA  = document.getElementById('revealA');
            const revealB  = document.getElementById('revealB');
            const final    = document.getElementById('revealFinal');
            const pathA    = document.getElementById('pathA');
            const pathB    = document.getElementById('pathB');

            function choosePath(which) {
                pathsEl.classList.remove('chose-a', 'chose-b');
                revealA.classList.remove('active');
                revealB.classList.remove('active');
                // Convergence always shows after either path is chosen.
                final.classList.add('active');

                if (which === 'a') {
                    pathsEl.classList.add('chose-a');
                    revealA.classList.add('active');
                    setTimeout(() => revealA.scrollIntoView({ behavior: 'smooth', block: 'start' }), 80);
                } else {
                    pathsEl.classList.add('chose-b');
                    revealB.classList.add('active');
                    setTimeout(() => revealB.scrollIntoView({ behavior: 'smooth', block: 'start' }), 80);
                }

                // Re-trigger step animations by removing + forcing reflow + re-adding
                const active = which === 'a' ? revealA : revealB;
                active.querySelectorAll('.fork-step').forEach(el => {
                    el.style.animation = 'none';
                    // Force reflow
                    void el.offsetWidth;
                    el.style.animation = '';
                });
            }

            pathA.addEventListener('click', () => choosePath('a'));
            pathB.addEventListener('click', () => choosePath('b'));

            // Exposed for restart buttons
            window.forkRestart = function () {
                revealA.classList.remove('active');
                revealB.classList.remove('active');
                final.classList.remove('active');
                pathsEl.classList.remove('chose-a', 'chose-b');
                pathsEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            };
        })();
    </script>
