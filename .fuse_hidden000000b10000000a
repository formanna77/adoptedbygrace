    <style>
        /* ────────────────────────────────────────────────────────
           THE FORK IN THE ROAD — interactive Crown Jewel page.
           Inline CSS is permitted for interactive widgets (per CLAUDE.md).
           All colors use the site's canonical variables from /global.css.
           ──────────────────────────────────────────────────────── */

        .fork-stage {
            max-width: 1080px;
            margin: 0 auto;
            padding: 0.5rem 1.5rem 4rem;
        }

        /* THE CENTRAL QUESTION */
        .fork-question {
            font-family: 'Crimson Text', Georgia, serif;
            font-size: clamp(2rem, 5.5vw, 3.75rem);
            line-height: 1.15;
            text-align: center;
            color: var(--text-primary);
            margin: 0 0 1rem;
            font-weight: 400;
            letter-spacing: -0.015em;
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-ember));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .fork-subquestion {
            text-align: center;
            color: var(--text-muted);
            font-size: clamp(1rem, 1.6vw, 1.15rem);
            max-width: 720px;
            margin: 0 auto 0.5rem;
            line-height: 1.7;
        }

        .fork-scripture-hint {
            text-align: center;
            font-family: monospace;
            font-size: 0.8rem;
            color: var(--accent-gold);
            letter-spacing: 0.2em;
            margin: 0 auto 3rem;
            opacity: 0.8;
        }

        /* TWO PATHS */
        .fork-paths {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin: 3rem 0;
        }
        @media (max-width: 760px) {
            .fork-paths { grid-template-columns: 1fr; }
        }

        .fork-path {
            background: linear-gradient(135deg, rgba(212, 162, 84, 0.07), rgba(232, 100, 44, 0.03));
            border: 1px solid rgba(212, 162, 84, 0.28);
            border-radius: 14px;
            padding: 2.5rem 2rem;
            cursor: pointer;
            transition: all 0.45s cubic-bezier(0.16, 1, 0.3, 1);
            text-align: left;
            position: relative;
            overflow: hidden;
            font-family: inherit;
            color: inherit;
            width: 100%;
        }
        .fork-path::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 50% 0%, rgba(212, 162, 84, 0.18), transparent 70%);
            opacity: 0;
            transition: opacity 0.5s;
            pointer-events: none;
        }
        .fork-path:hover::before { opacity: 1; }
        .fork-path:hover {
            border-color: rgba(212, 162, 84, 0.7);
            transform: translateY(-5px);
            box-shadow: 0 16px 48px rgba(212, 162, 84, 0.22);
        }
        .fork-path:focus-visible {
            outline: 2px solid var(--accent-gold);
            outline-offset: 4px;
        }

        .fork-path-label {
            font-family: monospace;
            font-size: 0.72rem;
            color: var(--accent-gold);
            letter-spacing: 0.22em;
            text-transform: uppercase;
            margin-bottom: 1.25rem;
        }
        .fork-path-claim {
            font-family: 'Crimson Text', Georgia, serif;
            font-size: clamp(1.25rem, 2.2vw, 1.6rem);
            color: var(--text-primary);
            margin-bottom: 0.75rem;
            font-weight: 400;
            line-height: 1.3;
        }
        .fork-path-hint {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        .fork-path-go {
            color: var(--accent-gold);
            font-size: 0.9rem;
            font-weight: 600;
            position: relative;
            z-index: 1;
            font-family: monospace;
            letter-spacing: 0.08em;
        }
        .fork-path-go::after {
            content: ' →';
            transition: transform 0.35s;
            display: inline-block;
        }
        .fork-path:hover .fork-path-go::after {
            transform: translateX(8px);
        }

        /* THE REVEAL PANES */
        .fork-reveal {
            display: none;
            animation: fadeInUp 0.75s cubic-bezier(0.16, 1, 0.3, 1) both;
            margin-top: 2rem;
        }
        .fork-reveal.active { display: block; }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .fork-reveal-intro {
            font-family: 'Crimson Text', Georgia, serif;
            font-size: clamp(1.4rem, 2.6vw, 1.85rem);
            color: var(--text-primary);
            line-height: 1.4;
            margin: 1rem 0 2rem;
            font-weight: 400;
        }
        .fork-reveal-intro strong {
            color: var(--accent-gold);
            font-weight: 600;
        }

        /* LOGIC STEPS */
        .fork-step {
            background: rgba(212, 162, 84, 0.045);
            border-left: 3px solid var(--accent-gold);
            padding: 1.5rem 1.75rem;
            margin: 1.5rem 0;
            border-radius: 0 10px 10px 0;
            opacity: 0;
            transform: translateX(-12px);
            animation: stepIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .fork-reveal.active .fork-step { opacity: 1; }
        .fork-reveal.active .fork-step:nth-child(2) { animation-delay: 0.1s; }
        .fork-reveal.active .fork-step:nth-child(3) { animation-delay: 0.25s; }
        .fork-reveal.active .fork-step:nth-child(4) { animation-delay: 0.4s; }
        .fork-reveal.active .fork-step:nth-child(5) { animation-delay: 0.55s; }
        .fork-reveal.active .fork-step:nth-child(6) { animation-delay: 0.7s; }
        .fork-reveal.active .fork-step:nth-child(7) { animation-delay: 0.85s; }
        .fork-reveal.active .fork-step:nth-child(8) { animation-delay: 1s; }

        @keyframes stepIn {
            to { opacity: 1; transform: translateX(0); }
        }

        .fork-step-num {
            font-family: monospace;
            color: var(--accent-gold);
            font-size: 0.75rem;
            letter-spacing: 0.2em;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
        }
        .fork-step p {
            color: var(--text-secondary);
            line-height: 1.75;
            margin: 0.4rem 0;
            font-size: 1.02rem;
        }
        .fork-step strong {
            color: var(--text-primary);
        }

        /* THE TRAP BOX (path B only) */
        .fork-trap {
            background: linear-gradient(135deg, rgba(232, 100, 44, 0.09), rgba(212, 162, 84, 0.04));
            border: 1px solid rgba(232, 100, 44, 0.38);
            padding: 2rem 2rem;
            margin: 2.5rem 0;
            border-radius: 14px;
            position: relative;
        }
        .fork-trap-title {
            color: var(--accent-ember);
            font-family: 'Crimson Text', Georgia, serif;
            font-size: clamp(1.35rem, 2.4vw, 1.75rem);
            margin-bottom: 1rem;
            line-height: 1.3;
        }
        .fork-trap p {
            color: var(--text-secondary);
            line-height: 1.75;
            margin: 0.75rem 0;
        }

        /* CONVERGENCE PANEL (both paths end here) */
        .fork-final {
            margin-top: 3rem;
            padding: 3rem 2.5rem;
            background: linear-gradient(135deg, rgba(212, 162, 84, 0.14), rgba(232, 100, 44, 0.07));
            border-radius: 16px;
            border: 1px solid rgba(212, 162, 84, 0.42);
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .fork-final::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 50% 30%, rgba(212, 162, 84, 0.12), transparent 60%);
            pointer-events: none;
        }
        .fork-final h2 {
            font-family: 'Crimson Text', Georgia, serif;
            color: var(--accent-gold);
            margin-bottom: 1.25rem;
            font-size: clamp(1.75rem, 3.5vw, 2.35rem);
            font-weight: 400;
            line-height: 1.3;
            position: relative;
        }
        .fork-final p {
            color: var(--text-secondary);
            line-height: 1.75;
            max-width: 720px;
            margin: 0 auto 1.25rem;
            font-size: 1.05rem;
            position: relative;
        }

        .fork-verse {
            font-family: 'Crimson Text', Georgia, serif;
            font-style: italic;
            color: var(--text-primary);
            font-size: clamp(1.05rem, 2vw, 1.2rem);
            line-height: 1.75;
            margin: 2.5rem auto;
            padding: 1.25rem 2rem;
            border-left: 3px solid var(--accent-gold);
            max-width: 640px;
            text-align: left;
            background: rgba(212, 162, 84, 0.04);
            border-radius: 0 8px 8px 0;
            position: relative;
        }
        .fork-verse cite {
            display: block;
            font-style: normal;
            color: var(--accent-gold);
            font-family: monospace;
            font-size: 0.82rem;
            margin-top: 0.75rem;
            letter-spacing: 0.12em;
        }

        /* RESTART BUTTON */
        .fork-restart {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 2rem;
            padding: 0.85rem 1.75rem;
            background: transparent;
            border: 1px solid rgba(212, 162, 84, 0.45);
            color: var(--accent-gold);
            border-radius: 10px;
            cursor: pointer;
            font-family: inherit;
            font-size: 0.92rem;
            font-weight: 500;
            transition: all 0.35s;
            letter-spacing: 0.02em;
        }
        .fork-restart:hover {
            background: rgba(212, 162, 84, 0.1);
            border-color: var(--accent-gold);
            transform: translateY(-2px);
        }

        /* CATCH-ARM LINKS (hub cards) */
        .fork-catch {
            margin-top: 4rem;
            padding-top: 3rem;
            border-top: 1px solid rgba(212, 162, 84, 0.2);
        }
        .fork-catch-heading {
            font-family: 'Crimson Text', Georgia, serif;
            font-size: clamp(1.5rem, 3vw, 2rem);
            color: var(--accent-gold);
            text-align: center;
            margin-bottom: 0.75rem;
            font-weight: 400;
        }
        .fork-catch-bridge {
            text-align: center;
            color: var(--text-muted);
            max-width: 680px;
            margin: 0 auto 2.5rem;
            line-height: 1.7;
            font-size: 1.02rem;
            font-style: italic;
        }

        /* DISABLE THE PATH THAT WASN'T CHOSEN AFTER PICK (optional visual) */
        .fork-paths.chose-a .fork-path[data-path="b"] {
            opacity: 0.45;
            pointer-events: none;
        }
        .fork-paths.chose-b .fork-path[data-path="a"] {
            opacity: 0.45;
            pointer-events: none;
        }

        /* INLINE LINK STYLING inside reveal content */
        .fork-reveal a, .fork-final a {
            color: var(--accent-gold);
            text-decoration: none;
            border-bottom: 1px dashed rgba(212, 162, 84, 0.5);
            transition: all 0.25s;
        }
        .fork-reveal a:hover, .fork-final a:hover {
            color: var(--accent-ember);
            border-bottom-color: var(--accent-ember);
        }
    </style>

