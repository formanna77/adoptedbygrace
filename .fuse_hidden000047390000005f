    <!-- Hero -->
    <section class="page-hero" style="text-align:center; max-width:900px; margin:0 auto; padding:3rem 2rem 2rem;">
        <p class="eyebrow" style="font-family:'JetBrains Mono',monospace; font-size:0.75rem; color:var(--accent-gold); text-transform:uppercase; letter-spacing:0.15em; margin-bottom:1rem;">Reformed Catechism &bull; 1563</p>
        <h1 style="font-family:'Playfair Display',serif; font-size:3rem; font-weight:800; line-height:1.15; margin-bottom:1.5rem;">The Heidelberg Catechism</h1>
        <p style="font-size:1.1rem; color:var(--text-secondary); max-width:700px; margin:0 auto; line-height:1.8;">129 questions. One answer. <strong style="color:var(--text-primary);">I am not my own, but belong&mdash;body and soul, in life and in death&mdash;to my faithful Savior, Jesus Christ.</strong></p>
    </section>

    <div style="max-width:900px; margin:0 auto; padding:0 2rem;">

    <!-- Quick Navigation -->
    <div class="catechism-nav">
        <a href="#comfort">The Comfort</a>
        <a href="#part-one">Part I: Misery</a>
